@page "{id:int}"
@model ftpms.Pages.Customers.DetailsModel
@{
    ViewData["Title"] = "Customer Details";
}

<div class="card">
    @if (Model.Customer is null)
    {
        <p>Customer not found.</p>
    }
    else
    {
        <h2>@Model.Customer.FirstName @Model.Customer.LastName</h2>
        <p><strong>Email:</strong> @Model.Customer.Email</p>
        <p><strong>Phone:</strong> @Model.Customer.PhoneNumber</p>
        <p><strong>Address:</strong> @Model.Customer.Address</p>

        <hr />
        <h4>Measurement History</h4>

        <div class="mb-3 d-flex gap-2">
            <a asp-page="/Measurements/Create" asp-route-customerId="@Model.Customer.Id" class="btn btn-success">Create New Measurement</a>
            <a asp-page="/Measurements/History" asp-route-customerId="@Model.Customer.Id" class="btn btn-outline-primary">View Full Measurement History</a>
        </div>

        <table class="table table-sm table-striped">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Template</th>
                    <th>Version</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.MeasurementHistory.Count == 0)
                {
                    <tr><td colspan="4">No measurement records yet.</td></tr>
                }
                else
                {
                    foreach (var item in Model.MeasurementHistory)
                    {
                        <tr>
                            <td>@item.DateTaken.ToString("yyyy-MM-dd")</td>
                            <td>@item.TemplateType</td>
                            <td>v@item.Version</td>
                            <td><a asp-page="/Measurements/Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Details</a></td>
                        </tr>
                    }
                }
            </tbody>
        </table>

        <div class="actions">
            <a asp-page="Edit" asp-route-id="@Model.Customer.Id" class="btn btn-primary">Edit</a>
            <a asp-page="Index" class="btn btn-secondary">Back</a>
        </div>
    }
</div>
