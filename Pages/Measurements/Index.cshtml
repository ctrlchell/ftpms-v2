@page
@model ftpms.Pages.Measurements.IndexModel
@{
    ViewData["Title"] = "Measurements";
}

<div class="card">
    <h2>Measurements</h2>

    <form method="get" class="row g-3 mb-3">
        <div class="col-md-4">
            <label asp-for="CustomerId" class="form-label">Customer</label>
            <select asp-for="CustomerId" asp-items="Model.CustomerOptions" class="form-control">
                <option value="">All customers</option>
            </select>
        </div>
        <div class="col-md-4">
            <label asp-for="TemplateType" class="form-label">Template Type</label>
            <select asp-for="TemplateType" asp-items="Model.TemplateOptions" class="form-control">
                <option value="">All templates</option>
            </select>
        </div>
        <div class="col-md-4 d-flex align-items-end gap-2">
            <button type="submit" class="btn btn-primary">Filter</button>
            <a asp-page="Create" asp-route-customerId="@Model.CustomerId" asp-route-templateType="@Model.TemplateType" class="btn btn-success">New Measurement</a>
        </div>
    </form>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Customer</th>
                <th>Template</th>
                <th>Version</th>
                <th>Date Taken</th>
                <th>Active</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Measurements.Count == 0)
            {
                <tr><td colspan="6">No measurements found.</td></tr>
            }
            else
            {
                foreach (var item in Model.Measurements)
                {
                    <tr>
                        <td>@item.CustomerName</td>
                        <td>@item.TemplateType</td>
                        <td>v@item.Version</td>
                        <td>@item.DateTaken.ToString("yyyy-MM-dd")</td>
                        <td>@(item.IsActive ? "Yes" : "No")</td>
                        <td>
                            <a asp-page="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Details</a>
                            <a asp-page="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                            <a asp-page="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
