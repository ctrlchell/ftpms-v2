@page "{id:int}"
@model ftpms.Pages.Measurements.DeleteModel
@{
    ViewData["Title"] = "Delete Measurement";
}

<div class="card">
    @if (Model.Measurement is null)
    {
        <p>Measurement not found.</p>
    }
    else
    {
        <h2>Delete Measurement</h2>
        <p>Are you sure you want to delete this record?</p>
        <p><strong>Customer:</strong> @Model.Measurement.CustomerName</p>
        <p><strong>Template:</strong> @Model.Measurement.TemplateType</p>
        <p><strong>Version:</strong> @Model.Measurement.Version</p>

        <form method="post">
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-page="Details" asp-route-id="@Model.Measurement.Id" class="btn btn-secondary">Cancel</a>
        </form>
    }
</div>
