@page
@model ftpms.Pages.Measurements.HistoryModel
@{
    ViewData["Title"] = "Measurement History";
}

<div class="card">
    <h2>Measurement History - @Model.CustomerName</h2>

    <form method="get" class="row g-3 mb-3">
        <input type="hidden" asp-for="CustomerId" />
        <div class="col-md-4">
            <label asp-for="TemplateType" class="form-label">Template Type</label>
            <select asp-for="TemplateType" asp-items="Model.TemplateOptions" class="form-control">
                <option value="">All templates</option>
            </select>
        </div>
        <div class="col-md-8 d-flex align-items-end gap-2">
            <button type="submit" class="btn btn-primary">Filter</button>
            <a asp-page="Create" asp-route-customerId="@Model.CustomerId" asp-route-templateType="@Model.TemplateType" class="btn btn-success">Create New Version</a>
            <a asp-page="/Customers/Details" asp-route-id="@Model.CustomerId" class="btn btn-secondary">Back to Customer</a>
        </div>
    </form>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Date Taken</th>
                <th>Template</th>
                <th>Version</th>
                <th>Active</th>
                <th>Notes</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Items.Count == 0)
            {
                <tr><td colspan="6">No measurement history found.</td></tr>
            }
            else
            {
                foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.DateTaken.ToString("yyyy-MM-dd")</td>
                        <td>@item.TemplateType</td>
                        <td>v@item.Version</td>
                        <td>@(item.IsActive ? "Yes" : "No")</td>
                        <td>@item.Notes</td>
                        <td><a asp-page="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Details</a></td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
