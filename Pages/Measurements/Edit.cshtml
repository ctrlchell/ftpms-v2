@page "{id:int}"
@model ftpms.Pages.Measurements.EditModel
@{
    ViewData["Title"] = "Edit Measurement";
}

<div class="card">
    <h2>Edit Measurement</h2>
    <p class="text-muted">Editing updates this specific record only. Version history is preserved.</p>

    <form method="post">
        <div class="row g-3 mb-3">
            <div class="col-md-4">
                <label asp-for="Input.CustomerId" class="form-label">Customer</label>
                <select asp-for="Input.CustomerId" asp-items="Model.CustomerOptions" class="form-control"></select>
            </div>
            <div class="col-md-4">
                <label asp-for="Input.TemplateType" class="form-label">Template Type</label>
                <select asp-for="Input.TemplateType" asp-items="Model.TemplateOptions" class="form-control"></select>
            </div>
        </div>

        <partial name="_MeasurementForm" model="Model.Input" />

        <div class="mt-3 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a asp-page="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
